# --- PostgreSQL Database Credentials ---
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=enterpriserag
DATABASE_URL=postgresql://your_postgres_user:your_secure_password@db:5432/enterpriserag

# --- Microservices Connections ---
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

# --- Authentication ---
JWT_SECRET_KEY=replace_this_with_a_secure_random_string
JWT_ALGORITHM=HS256

# --- AI Model Providers ---
# Note: Add any API keys here if you swap out the mock LLM for a real one (e.g., OpenAI, Gemini, Groq)
OPENAI_API_KEY=your_api_key_placeholder